        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-30" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="a4QuxEcS3XgPXXnMmP8I-20" target="a4QuxEcS3XgPXXnMmP8I-25">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-20" value="Software" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="619" y="1007.5" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-25" value="&lt;b&gt;Software&amp;nbsp;&lt;/b&gt;&lt;div&gt;pas de gros problème, ne fait que réduire la qualité utilisauter&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;" vertex="1" parent="1">
          <mxGeometry x="639" y="1133" width="80" height="182" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-26" value="&lt;div&gt;&lt;b&gt;Firmware&lt;/b&gt;&lt;/div&gt;&lt;div&gt;Pas de faute sur le système au complet. Mais la donné qui a manqué son deadline n&#39;a pus de valeur. On peut avoir un timout pis jeter la donné.&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;" vertex="1" parent="1">
          <mxGeometry x="490.5" y="1117" width="103" height="239" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-27" value="&lt;div&gt;C&#39;est les conséquence de manqué une deadline&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Il faut détecter lorsque la deadline et manqué, et réagir accordingly selon la gravité de la faute&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;" vertex="1" parent="1">
          <mxGeometry x="89" y="949" width="234" height="149" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-28" value="&lt;div&gt;&lt;b&gt;Hardware&lt;/b&gt;&lt;/div&gt;&lt;div&gt;Le système au complet tombe en faute si la donné&amp;nbsp; manque sa deadline&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;" vertex="1" parent="1">
          <mxGeometry x="370" y="1123" width="80" height="182" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-34" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0;entryY=0.5;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="1" source="a4QuxEcS3XgPXXnMmP8I-13" target="a4QuxEcS3XgPXXnMmP8I-16">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-35" value="&lt;span style=&quot;font-size: 10px;&quot;&gt;Jitter : lorsque le fin d&quot;une tache est décalé de l&#39;endroit prévue.&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;Risque je jitter dans l&#39;app - sortir les échantillions (jouer une note). On mitige ce risque avec le buffer.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;" vertex="1" parent="1">
          <mxGeometry x="953" y="808" width="181" height="152" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-36" value="Robustesse&amp;nbsp;&lt;div&gt;Capcité de resiter aux changement externe (resitance a la poussière, vibration, etc)&amp;nbsp;&lt;/div&gt;&lt;div&gt;Robustesse electrique (avoir un range de vlotage qui va pas peter tes composante)&lt;/div&gt;&lt;div&gt;Robustesse logiciel (se proteger des inputs du user - ex regex sur un courriel)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Tolérence&lt;/div&gt;&lt;div&gt;&lt;div&gt;Capcité de resiter aux changement iterne&lt;/div&gt;&lt;div&gt;Avoir de la détection de faute.&amp;nbsp;&lt;/div&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;" vertex="1" parent="1">
          <mxGeometry x="822" y="1005" width="312" height="262" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-38" value="ACITVE - actuellement en execusion&amp;nbsp;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;EADY tache non bloque qui pourrait a tout moment se faire exécuter&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;BLOQUÉ - est une tache qui existe. mais est non candidate à l&#39;exécution car elle est en attente&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;INNACTIVE tache qui n&#39;existe pas, a été supprimé, jamais initialisé or smt else&amp;nbsp;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;" vertex="1" parent="1">
          <mxGeometry x="1207" y="885" width="183" height="341" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
