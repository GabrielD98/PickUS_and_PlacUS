        <mxCell id="a4QuxEcS3XgPXXnMmP8I-2" value="Scheduler&amp;nbsp;" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="217" y="639" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-3" value="&lt;b&gt;Préemptif&lt;/b&gt;&lt;div&gt;peut spliter une tache dans un tick&lt;/div&gt;" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="53" y="783" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-4" value="&lt;b&gt;non-préemptif&lt;/b&gt;&lt;div&gt;ne peut pas spliter des taches dans un tick&lt;/div&gt;" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="217" y="783" width="120" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-9" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;c quoi qui différencie preemptif vs non-premptif&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;algo du scheduler est le meme, la dfiference est que en premptif, on a une tache qui verifie periodiquement l&#39;etat des tache, vs non-premptif c&#39;est les taches eux meme qui appel le scheduler (taskYIELD)&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;en gros, dans le non-premnptif, la tache elle meme a le control lorsqu&#39;elle change de context&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;non premptif est rare dans des systeme complexe, car la compexite augmente rapidement, donc on ne veut pas prendre de chance&lt;/font&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;" vertex="1" parent="1">
          <mxGeometry x="-280" y="750" width="263" height="280" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-14" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="a4QuxEcS3XgPXXnMmP8I-10" target="a4QuxEcS3XgPXXnMmP8I-13">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-24" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="a4QuxEcS3XgPXXnMmP8I-10" target="a4QuxEcS3XgPXXnMmP8I-17">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-10" value="Prog temps réel embarqué" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="402" y="656" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.45;entryY=0.975;entryDx=0;entryDy=0;entryPerimeter=0;" edge="1" parent="1" source="a4QuxEcS3XgPXXnMmP8I-10" target="a4QuxEcS3XgPXXnMmP8I-1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-12" value="&lt;span style=&quot;font-size: 10px;&quot;&gt;Tache a priorité egale - elle vont a tour de role embarqué l&#39;une par dessus les autres.&amp;nbsp;&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;Avantage : Tu tu raproche le plus possible du parallélisme (les tache vont alterner)&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;Désavange : ya plus de changement de context (ya un petit cout de cycle de CPU)&lt;/span&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;" vertex="1" parent="1">
          <mxGeometry x="-275" y="508" width="182" height="229" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-33" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="a4QuxEcS3XgPXXnMmP8I-13" target="a4QuxEcS3XgPXXnMmP8I-15">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-13" value="Communication inter-tâche" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="662" y="407" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-15" value="&lt;span style=&quot;font-size: 10px;&quot;&gt;Fonction réentrante : stack de fct (contient param, varianle local et return adress)&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;Si cette fonction utilise seulement le contenue de sa stack, pour une entré donné elle va toujour donné le même résultat. (pas de variable global, static). Si une fonction respecte ceci, elle est réentrante.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;Pour se protégé si non réentrente : mutex, event group, etc&lt;/span&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;" vertex="1" parent="1">
          <mxGeometry x="990.5" y="287" width="208" height="225" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-16" value="&lt;div&gt;&lt;span style=&quot;font-size: 10px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Les ISR devrait etre réentrante, ça serait bonne pratique qu&#39;elle soit réentrante.&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;Dans arduino, il est impossible d&#39;interompre une interuption. Une autre solution serait d&#39;avoir une queue d&#39;interpution selon leur ordre&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;La derinere solution serait d&#39;avoir des ordre de priorité dans les interuptions, mais cette solution pourrait causer des problème&lt;/span&gt;&lt;/div&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;" vertex="1" parent="1">
          <mxGeometry x="990.5" y="535" width="195" height="231" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-21" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="a4QuxEcS3XgPXXnMmP8I-17" target="a4QuxEcS3XgPXXnMmP8I-18">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-22" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="a4QuxEcS3XgPXXnMmP8I-17" target="a4QuxEcS3XgPXXnMmP8I-19">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="a4QuxEcS3XgPXXnMmP8I-17" target="a4QuxEcS3XgPXXnMmP8I-20">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a4QuxEcS3XgPXXnMmP8I-29" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="a4QuxEcS3XgPXXnMmP8I-17" target="a4QuxEcS3XgPXXnMmP8I-27">
          <mxGeometry relative="1" as="geometry" />
